# API server
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/life_hub_nexus

# Identity provider
# Non-secret values only. See docs/architecture/identity-decision.md for the
# provider-neutral contract. The real verifier adapter is wired in T-016;
# until then the server uses a placeholder that rejects every token.
AUTH_ISSUER_URL=https://example-issuer.local/
AUTH_AUDIENCE=https://api.lifehubnexus.example
AUTH_CLIENT_ID=dev-client-id
AUTH_TOKEN_ALGORITHM=RS256

# Optional provider-specific non-secret values (uncomment and set after T-016.02):
# AUTH_REDIRECT_URI=https://api.lifehubnexus.example/auth/callback
# AUTH_TOKEN_ISSUER=https://example-issuer.local/
# AUTH_JWKS_URI=https://example-issuer.local/.well-known/jwks.json
# AUTH_DEEP_LINK_SCHEME=lifehubnexus://auth/callback
